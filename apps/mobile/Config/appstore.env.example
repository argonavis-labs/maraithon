# Copy to apps/mobile/Config/appstore.env and fill in real values.
# This file is sourced by `make ship-mobile` (and apps/mobile/scripts/upload.sh)
# so uploads work with one command.
#
# The .p8 must exist at ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8

APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
