#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib.sh"

component="${1:-all}"

validate_component "${component}" all native web api companion mac mobile ios assets static

case "${component}" in
  assets)
    "${ROOT_DIR}/scripts/monorepo/assets" all
    exit
    ;;
  static)
    "${ROOT_DIR}/scripts/monorepo/assets" web
    exit
    ;;
esac

if selected_component "${component}" "web"; then
  run_in "${ROOT_DIR}" env MIX_ENV="${MARAITHON_WEB_BUILD_ENV:-dev}" mix compile --warnings-as-errors
fi

if selected_component "${component}" "companion"; then
  generate_xcode_project "${COMPANION_DIR}"
  run_in "${COMPANION_DIR}" swift build
  companion_signing_args=()
  while IFS= read -r arg; do
    companion_signing_args+=("${arg}")
  done < <(companion_xcode_signing_args)

  companion_build_args=(
    -project Maraithon.xcodeproj
    -scheme Maraithon
    -configuration Debug
    -destination "platform=macOS"
  )
  if [[ -n "${MARAITHON_COMPANION_DERIVED_DATA_PATH:-}" ]]; then
    companion_build_args+=(-derivedDataPath "${MARAITHON_COMPANION_DERIVED_DATA_PATH}")
  fi
  if [[ -n "${MARAITHON_COMPANION_CONFIGURATION_BUILD_DIR:-}" ]]; then
    companion_build_args+=("CONFIGURATION_BUILD_DIR=${MARAITHON_COMPANION_CONFIGURATION_BUILD_DIR}")
  fi

  run_in "${COMPANION_DIR}" xcodebuild \
    "${companion_build_args[@]}" \
    "${companion_signing_args[@]}" \
    build
fi

if selected_component "${component}" "mobile"; then
  destination="$(ios_destination)"
  generate_xcode_project "${MOBILE_DIR}"
  run_in "${MOBILE_DIR}" xcodebuild \
    -project MaraithonMobile.xcodeproj \
    -scheme MaraithonMobile \
    -configuration Debug \
    -destination "${destination}" \
    CODE_SIGNING_ALLOWED=NO \
    build
fi

echo
echo "Build completed for ${component}."
